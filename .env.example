# Required — Google Places API key
# Enable: Places API (New) or Places API at console.cloud.google.com
GOOGLE_API_KEY=your_google_places_api_key_here

# Optional — Yelp Fusion API key (adds Yelp ratings to results)
# Get one free at: https://www.yelp.com/developers/v3/manage_app
YELP_API_KEY=your_yelp_fusion_api_key_here
